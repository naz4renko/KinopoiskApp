<Page
    x:Class="KinopoiskApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:KinopoiskApp.ViewModels"
    xmlns:models="using:KinopoiskApp.Models"
    xmlns:views="using:KinopoiskApp.Views">


    <Page.DataContext>
        <vm:MainViewModel/>
    </Page.DataContext>

    <NavigationView x:Name="NavView"
                    SelectedItem="{x:Bind PageOneItem, Mode=OneWay}"
                    ItemInvoked="NavigationView_ItemInvoked"
                    IsBackButtonVisible="Collapsed">

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Фильмы" Icon="Video" x:Name="PageOneItem" Tag="movies"/>
            <NavigationViewItem Content="Избранное" Icon="Favorite" x:Name="PageTwoItem" Tag="favorites"/>
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame"/>
    </NavigationView>
    
</Page>
